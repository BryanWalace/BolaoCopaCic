rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Profiles: public read + write (no auth required)
    match /profiles/{profileId} {
      allow read: if true;
      allow write: if true;
    }

    // Matches: public read + write (admins edit results manually)
    match /matches/{matchId} {
      allow read: if true;
      allow write: if true;
    }

    // Bets: public read, write if match has no result and is in the future or occurred within 24 hours
    match /bets/{betId} {
      allow read: if true;

      allow create, update: if
        get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.resultA == null &&
        request.time - get(/databases/$(database)/documents/matches/$(request.resource.data.matchId)).data.date < duration.value(24, 'h');

      allow delete: if true;
    }
  }
}
